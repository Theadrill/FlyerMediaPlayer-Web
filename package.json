{
  "name": "flyermediaplayer-web",
  "version": "1.0.0",
  "productName": "FlyerMediaPlayer",
  "description": "Digital signage player - plays videos from USB drive in MAIN→random→random loop",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.flyermediaplayer.app",
    "win": {
      "target": "portable",
      "artifactName": "${productName}.${ext}"
    },
    "files": [
      "**/*",
      "!dist"
    ]
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "electron-winstaller@5.4.0": true
  }
}
